# ══════════════════════════════════════════════
# PCMS — Environment Variables
# Copy this to .env.local and fill in values
# ══════════════════════════════════════════════

# ── Database ─────────────────────────────────
# Local PostgreSQL: postgresql://USER:PASS@localhost:5432/pcms
# Docker:          postgresql://postgres:postgres@localhost:5432/pcms
# Supabase:        postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pcms"

# ── Mojo Helpdesk API ─────────────────────────
# Your Mojo Helpdesk API base URL (tickets endpoint)
MOJO_API_BASE_URL="https://support.yourdomain.com/api/v2/tickets"
# Your Mojo Helpdesk access key
MOJO_API_TOKEN="f80ac2c71fd1eedccffce49235811935b27a855c"
# Your Mojo Helpdesk portal base URL
MOJO_PORTAL_BASE_URL="https://support.gulbrandsen.com"

# ── Google Drive Picker ─────────────────────────
# Browser API key for Google Picker / Drive APIs
NEXT_PUBLIC_GOOGLE_API_KEY=""
# OAuth client ID for Google Identity Services
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
# Google Cloud project number / app ID
NEXT_PUBLIC_GOOGLE_APP_ID=""

# ── App ───────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="PCMS"

# ── Auth (Future — leave as-is for mock mode) ─
NEXTAUTH_SECRET="change-me-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
